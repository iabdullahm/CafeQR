
{
  "entities": {
    "Plan": {
      "title": "Plan",
      "description": "Global subscription plan definitions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "description": { "type": "string" },
        "priceMonthly": { "type": "number" },
        "maxBranches": { "type": "number" },
        "maxTables": { "type": "number" },
        "maxProducts": { "type": "number" },
        "hasLoyalty": { "type": "boolean" },
        "hasMultiBranch": { "type": "boolean" },
        "hasAdvancedAnalytics": { "type": "boolean" }
      }
    },
    "Cafe": {
      "title": "Cafe",
      "description": "Root tenant entity for a cafe business.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "logoUrl": { "type": "string" },
        "currency": { "type": "string" },
        "timezone": { "type": "string" },
        "taxPercent": { "type": "number" },
        "serviceFee": { "type": "number" },
        "isActive": { "type": "boolean" },
        "subscription": {
          "type": "object",
          "properties": {
            "planId": { "type": "string" },
            "status": { "type": "string" },
            "endsAt": { "type": "string", "format": "date-time" }
          }
        }
      }
    },
    "User": {
      "title": "User",
      "description": "User profile and role association.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "cafeId": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "OWNER", "MANAGER", "STAFF"] },
        "isActive": { "type": "boolean" }
      }
    },
    "Branch": {
      "title": "Branch",
      "description": "A physical location of a cafe.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "cafeId": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE", "MAINTENANCE"] }
      }
    },
    "Table": {
      "title": "Table",
      "description": "A dining table or ordering slot within a branch.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "cafeId": { "type": "string" },
        "branchId": { "type": "string" },
        "number": { "type": "number" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["DINE_IN", "OUTDOOR", "CAR_SERVICE"] },
        "status": { "type": "string", "enum": ["AVAILABLE", "OCCUPIED", "RESERVED", "OUT_OF_SERVICE"] }
      }
    },
    "Category": {
      "title": "Category",
      "description": "A menu category.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "cafeId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "sortOrder": { "type": "number" },
        "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] }
      }
    },
    "Product": {
      "title": "Product",
      "description": "A menu item.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "cafeId": { "type": "string" },
        "categoryId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE", "OUT_OF_STOCK"] }
      }
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "cafeId": { "type": "string" },
        "branchId": { "type": "string" },
        "tableId": { "type": "string" },
        "orderNumber": { "type": "number" },
        "status": { "type": "string", "enum": ["NEW", "PREPARING", "READY", "COMPLETED", "CANCELLED"] },
        "totalAmount": { "type": "number" },
        "guestCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/plans/{planId}",
        "definition": {
          "entityName": "Plan",
          "schema": { "$ref": "#/backend/entities/Plan" },
          "description": "Global subscription plans."
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles. matches auth.uid."
        }
      },
      {
        "path": "/cafes/{cafeId}",
        "definition": {
          "entityName": "Cafe",
          "schema": { "$ref": "#/backend/entities/Cafe" },
          "description": "Cafe tenant root."
        }
      },
      {
        "path": "/cafes/{cafeId}/branches/{branchId}",
        "definition": {
          "entityName": "Branch",
          "schema": { "$ref": "#/backend/entities/Branch" },
          "description": "Cafe branches."
        }
      },
      {
        "path": "/cafes/{cafeId}/branches/{branchId}/tables/{tableId}",
        "definition": {
          "entityName": "Table",
          "schema": { "$ref": "#/backend/entities/Table" },
          "description": "Tables within a branch. Includes denormalized cafeId."
        }
      },
      {
        "path": "/cafes/{cafeId}/categories/{categoryId}",
        "definition": {
          "entityName": "Category",
          "schema": { "$ref": "#/backend/entities/Category" },
          "description": "Menu categories for a cafe."
        }
      },
      {
        "path": "/cafes/{cafeId}/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": { "$ref": "#/backend/entities/Product" },
          "description": "Menu products for a cafe."
        }
      },
      {
        "path": "/cafes/{cafeId}/orders/{orderId}",
        "definition": {
          "entityName": "Order",
          "schema": { "$ref": "#/backend/entities/Order" },
          "description": "Orders for a cafe. Includes denormalized branchId."
        }
      }
    ]
  }
}
