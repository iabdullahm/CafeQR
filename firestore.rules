
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isCafeAdmin(cafeId) {
      let user = getUserData();
      return isSignedIn() && user.cafeId == cafeId && (user.role == 'OWNER' || user.role == 'MANAGER');
    }

    function isSuperAdmin() {
      return isSignedIn() && getUserData().role == 'SUPER_ADMIN';
    }

    // --- RULES ---

    match /plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow list: if isSuperAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    match /cafes/{cafeId} {
      allow get: if true;
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isCafeAdmin(cafeId) || isSuperAdmin();

      match /branches/{branchId} {
        allow read: if true;
        allow write: if isCafeAdmin(cafeId);

        match /tables/{tableId} {
          allow read: if true;
          allow write: if isCafeAdmin(cafeId);
        }
      }

      match /categories/{categoryId} {
        allow read: if true;
        allow write: if isCafeAdmin(cafeId);
      }

      match /products/{productId} {
        allow read: if true;
        allow write: if isCafeAdmin(cafeId);
      }

      match /orders/{orderId} {
        allow read: if isCafeAdmin(cafeId);
        allow create: if true; // Public ordering
        allow update: if isCafeAdmin(cafeId);
      }
    }
    
    // Collection Group Queries for Tables
    // Optimized for performance and query validation
    match /{path=**}/tables/{tableId} {
      allow list: if isSignedIn() && 
                  resource.data.cafeId == getUserData().cafeId && 
                  (getUserData().role == 'OWNER' || getUserData().role == 'MANAGER' || getUserData().role == 'STAFF');
    }

    // Collection Group Queries for Orders
    match /{path=**}/orders/{orderId} {
      allow list: if isSignedIn() && 
                  resource.data.cafeId == getUserData().cafeId && 
                  (getUserData().role == 'OWNER' || getUserData().role == 'MANAGER' || getUserData().role == 'STAFF');
    }
  }
}
