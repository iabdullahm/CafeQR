
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // --- RULES ---

    match /plans/{planId} {
      allow read: if true;
      allow write: if isSignedIn() && getUserData().role == 'SUPER_ADMIN';
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || getUserData().role == 'SUPER_ADMIN');
      allow list: if isSignedIn() && getUserData().role == 'SUPER_ADMIN';
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || getUserData().role == 'SUPER_ADMIN');
    }

    match /cafes/{cafeId} {
      allow get: if true;
      allow list: if isSignedIn() && getUserData().role == 'SUPER_ADMIN';
      allow create: if isSignedIn() && getUserData().role == 'SUPER_ADMIN';
      allow update: if isSignedIn() && (
        (getUserData().cafeId == cafeId && (getUserData().role == 'OWNER' || getUserData().role == 'MANAGER')) ||
        getUserData().role == 'SUPER_ADMIN'
      );

      // Generic rule for cafe-scoped resources
      match /{allSubcollections=**} {
        // Operational read access for all cafe staff
        allow read: if isSignedIn() && (
          getUserData().cafeId == cafeId || 
          getUserData().role == 'SUPER_ADMIN'
        );
        // Management write access
        allow write: if isSignedIn() && (
          (getUserData().cafeId == cafeId && (getUserData().role == 'OWNER' || getUserData().role == 'MANAGER')) ||
          getUserData().role == 'SUPER_ADMIN'
        );
      }
      
      // Special case for public ordering
      match /orders/{orderId} {
        allow create: if true;
      }
    }
    
    // Collection Group Queries for Tables
    // Optimized for the dashboard occupancy matrix
    match /{path=**}/tables/{tableId} {
      allow list: if isSignedIn() && 
                  resource.data.cafeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.cafeId;
    }

    // Collection Group Queries for Orders
    match /{path=**}/orders/{orderId} {
      allow list: if isSignedIn() && 
                  resource.data.cafeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.cafeId;
    }
  }
}
