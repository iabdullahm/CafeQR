
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Fetches the data of the currently signed-in user
    function getRequesterData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // --- RULES ---

    match /plans/{planId} {
      allow read: if true;
      allow write: if isSignedIn() && getRequesterData().role == 'SUPER_ADMIN';
    }

    match /users/{userId} {
      // Allow user to get their own profile without recursion
      // Super admins can get any profile
      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SUPER_ADMIN'
      );
      // List/Create/Update permissions
      allow list: if isSignedIn() && getRequesterData().role == 'SUPER_ADMIN';
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        getRequesterData().role == 'SUPER_ADMIN'
      );
    }

    match /cafes/{cafeId} {
      allow get: if true;
      allow list: if isSignedIn() && getRequesterData().role == 'SUPER_ADMIN';
      allow create: if isSignedIn() && getRequesterData().role == 'SUPER_ADMIN';
      
      // Scoped administrative write access
      allow update: if isSignedIn() && (
        (getRequesterData().cafeId == cafeId && (getRequesterData().role == 'OWNER' || getRequesterData().role == 'MANAGER')) ||
        getRequesterData().role == 'SUPER_ADMIN'
      );

      // Scoped operational read/write access for cafe staff
      match /{allSubcollections=**} {
        allow read: if isSignedIn() && (
          getRequesterData().cafeId == cafeId || 
          getRequesterData().role == 'SUPER_ADMIN'
        );
        allow write: if isSignedIn() && (
          (getRequesterData().cafeId == cafeId && (getRequesterData().role == 'OWNER' || getRequesterData().role == 'MANAGER')) ||
          getRequesterData().role == 'SUPER_ADMIN'
        );
      }
      
      // Public ordering
      match /orders/{orderId} {
        allow create: if true;
      }
    }
    
    // Collection Group Queries for Tables
    // Optimized for cross-branch monitoring on the dashboard
    match /{path=**}/tables/{tableId} {
      allow list: if isSignedIn() && (
        resource.data.cafeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.cafeId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SUPER_ADMIN'
      );
    }

    // Collection Group Queries for Orders
    match /{path=**}/orders/{orderId} {
      allow list: if isSignedIn() && (
        resource.data.cafeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.cafeId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SUPER_ADMIN'
      );
    }
  }
}
