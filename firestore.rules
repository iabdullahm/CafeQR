
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && (getUserData().role == 'SUPER_ADMIN' || getUserData().role == 'super_admin');
    }

    function belongsToCafe(cafeId) {
      return isSignedIn() && (getUserData().cafeId == cafeId || isSuperAdmin());
    }

    // --- RULES ---
    // Global Super Admin Override
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    match /addons/{addonId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    match /reports/{reportId} {
      allow read, write: if isSuperAdmin();
    }
    // Support tickets carry a cafeId field. Cafe staff see only their cafe;
    // super admins see everything. Any signed-in cafe user can open a ticket.
    match /supportTickets/{ticketId} {
      allow get: if isSignedIn() && (
        isSuperAdmin() ||
        (resource != null && getUserData().cafeId == resource.data.cafeId)
      );
      allow list: if isSuperAdmin();
      allow create: if isSignedIn() && (
        isSuperAdmin() ||
        request.resource.data.cafeId == getUserData().cafeId
      );
      allow update: if isSignedIn() && (
        isSuperAdmin() ||
        (resource != null && getUserData().cafeId == resource.data.cafeId)
      );
      allow delete: if isSuperAdmin();
    }

    // Notifications are super-admin-authored. Targets can be "All Cafes" or
    // a specific cafe via cafeId. Anyone signed in can read (client filters by
    // target); only super admins can mutate.
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /auditLogs/{logId} {
      allow read, write: if isSuperAdmin();
    }

    // Payment records carry a cafeId. Cafe staff see only their cafe's payments;
    // super admins see everything. Customers and unauthenticated users never see
    // any payment. All writes are super-admin only (creation happens server-side
    // / via billing webhook in production).
    match /payments/{paymentId} {
      allow get: if isSignedIn() && (
        isSuperAdmin() ||
        (resource != null && getUserData().cafeId == resource.data.cafeId)
      );
      allow list: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId || 
        isSuperAdmin() || 
        getUserData().cafeId == resource.data.cafeId
      );
      
      allow create: if isSignedIn() && (
        request.auth.uid == userId || 
        isSuperAdmin() || 
        (getUserData().cafeId == request.resource.data.cafeId && getUserData().role in ['OWNER', 'MANAGER'])
      );
      
      allow update, delete: if isSignedIn() && (
        request.auth.uid == userId || 
        isSuperAdmin() || 
        (getUserData().cafeId == resource.data.cafeId && getUserData().role in ['OWNER', 'MANAGER'])
      );
    }
    
    match /loyaltySettings/{cafeId} {
      allow read: if true;
      allow write: if belongsToCafe(cafeId) && (getUserData().role in ['OWNER', 'MANAGER'] || isSuperAdmin());
    }

    // Global customer loyalty docs keyed by "{cafeId}_{phone}".
    // Used by the unauthenticated ordering flow (CustomerMenuClient + orders-logic)
    // and by cafe-admin loyalty page. Doc carries a cafeId field.
    // (Was: allow read, write: if true.)
    // TODO: move loyalty mutation server-side; anonymous writes are a known design gap.
    match /customers/{customerId} {
      // Customer reads/creates/updates their own record during ordering
      allow get, create, update: if true;
      // List restricted to cafe staff who own the cafe (was: open to all)
      allow list: if isSignedIn() && (
        isSuperAdmin() ||
        (resource != null && getUserData().cafeId == resource.data.cafeId)
      );
    }

    match /cafes/{cafeId} {
      // Public menu view and login queries
      allow get: if true;
      allow list: if true;

      // Cafe onboarding restricted to super admins (was: allow create: if true)
      allow create: if isSuperAdmin();

      // Operational access for cafe staff
      allow read: if belongsToCafe(cafeId);
      allow update: if belongsToCafe(cafeId) && 
        (getUserData().role in ['OWNER', 'MANAGER'] || isSuperAdmin());

      // Simplified Sub-collections Rules (All scoped under cafeId)
      match /{allSubcollections=**} {
        allow read: if belongsToCafe(cafeId);
        allow write: if belongsToCafe(cafeId) && 
          (getUserData().role in ['OWNER', 'MANAGER'] || isSuperAdmin());
      }
      
      // Specific Public Overrides
      match /orders/{orderId} {
        // Customer (anonymous) creates and reads their order by unguessable doc id
        allow create: if true;
        allow read: if true;
        // Only cafe staff can change order status / amounts (was: allow update: if true)
        allow update: if belongsToCafe(cafeId);
      }
      match /products/{productId} {
        allow read: if true;
      }
      match /categories/{categoryId} {
        allow read: if true;
      }
      match /tables/{tableId} {
        // Customers can see the table info; only cafe staff can mutate it
        // (was: allow read, update: if true)
        allow read: if true;
        allow update: if belongsToCafe(cafeId);
      }
      match /customers/{customerId} {
        // Customer can register themselves and fetch their own record
        allow get, create: if true;
        // Only cafe staff can edit existing customer records or list them
        // (was: allow update: if true; allow list: if isSignedIn())
        allow update: if belongsToCafe(cafeId);
        allow list: if belongsToCafe(cafeId);
      }
      match /branches/{branchId} {
        allow read: if true;
      }
      match /branches/{branchId}/counters/{counterId} {
        // TODO: move sequential numbering server-side; for now still open
        // because ordering flow depends on client-side counter increments.
        allow read, write: if true;
      }
      match /loyalty/{phone} {
        // Customer can read their loyalty points; only staff can grant/modify
        // (was: allow read, write: if true)
        allow read: if true;
        allow write: if belongsToCafe(cafeId);
      }
      match /config/{document=**} {
        allow read: if true;
      }
    }

    // QR token resolver: customer (unauthenticated) fetches a token to know
    // which cafe/branch/table to load. Staff create/delete tokens for their
    // own cafe only; cross-cafe writes are forbidden.
    match /qr_tokens/{token} {
      allow get: if true;
      allow list: if isSuperAdmin();
      allow create: if isSignedIn() && (
        isSuperAdmin() ||
        request.resource.data.cafeId == getUserData().cafeId
      );
      allow update, delete: if isSignedIn() && (
        isSuperAdmin() ||
        (resource != null && getUserData().cafeId == resource.data.cafeId)
      );
    }
  }
}
