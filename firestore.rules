
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && getUserData().role == 'SUPER_ADMIN';
    }

    function belongsToCafe(cafeId) {
      return isSignedIn() && (getUserData().cafeId == cafeId || isSuperAdmin());
    }

    // --- RULES ---

    match /plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /users/{userId} {
      // Allow users to read and update their own profile
      // IMPORTANT: Non-recursive rule for self
      allow get, update, create: if isSignedIn() && request.auth.uid == userId;
      
      // Super Admins can manage all users
      allow list: if isSuperAdmin();
      allow read, write: if isSuperAdmin();
    }
    match /cafes/{cafeId} {
      // Public menu view and login queries
      allow get: if true;
      allow list: if true;
      
      // Creation restricted to Super Admins
      allow create: if isSuperAdmin();
      
      // Operational access for cafe staff
      allow read: if belongsToCafe(cafeId);
      allow update: if belongsToCafe(cafeId) && 
        (getUserData().role in ['OWNER', 'MANAGER'] || isSuperAdmin());

      // Simplified Sub-collections Rules (All scoped under cafeId)
      match /{allSubcollections=**} {
        allow read: if belongsToCafe(cafeId);
        allow write: if belongsToCafe(cafeId) && 
          (getUserData().role in ['OWNER', 'MANAGER'] || isSuperAdmin());
      }
      
      // Specific Public Overrides
      match /orders/{orderId} {
        allow create: if true;
      }
      match /products/{productId} {
        allow read: if true;
      }
      match /categories/{categoryId} {
        allow read: if true;
      }
      match /tables/{tableId} {
        allow read: if true;
      }
      match /branches/{branchId} {
        allow read: if true;
      }
      match /config/{document=**} {
        allow read: if true;
      }
    }
  }
}
