rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Fetches the data of the currently signed-in user without recursion
    function getSelfData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // --- RULES ---

    match /plans/{planId} {
      allow read: if true;
      allow write: if isSignedIn() && getSelfData().role == 'SUPER_ADMIN';
    }

    match /users/{userId} {
      // Allow users to read and update their own profile
      allow get, update: if isSignedIn() && request.auth.uid == userId;
      
      // Allow creation of own profile (initial signup)
      allow create: if isSignedIn() && request.auth.uid == userId;

      // Super Admins can manage all users
      allow list, get, write: if isSignedIn() && getSelfData().role == 'SUPER_ADMIN';
    }

    match /cafes/{cafeId} {
      // Cafes are public for menu viewing
      allow get: if true;
      
      // Admin list/create
      allow list, create: if isSignedIn() && getSelfData().role == 'SUPER_ADMIN';
      
      // Cafe staff read/write within their tenant
      allow read: if isSignedIn() && (getSelfData().cafeId == cafeId || getSelfData().role == 'SUPER_ADMIN');
      allow update: if isSignedIn() && (
        (getSelfData().cafeId == cafeId && (getSelfData().role == 'OWNER' || getSelfData().role == 'MANAGER')) ||
        getSelfData().role == 'SUPER_ADMIN'
      );

      // Sub-collections (branches, categories, products, orders, etc.)
      match /{allSubcollections=**} {
        allow read: if isSignedIn() && (getSelfData().cafeId == cafeId || getSelfData().role == 'SUPER_ADMIN');
        
        // Operation-specific writes
        allow write: if isSignedIn() && (
          (getSelfData().cafeId == cafeId && (getSelfData().role == 'OWNER' || getSelfData().role == 'MANAGER')) ||
          getSelfData().role == 'SUPER_ADMIN'
        );
      }
      
      // Allow public customers to create orders
      match /orders/{orderId} {
        allow create: if true;
      }
    }
    
    // --- COLLECTION GROUP RULES ---
    // Specifically optimized for the Cafe Admin Dashboard cross-branch queries

    match /{path=**}/tables/{tableId} {
      allow list: if isSignedIn() && (
        resource.data.cafeId == getSelfData().cafeId ||
        getSelfData().role == 'SUPER_ADMIN'
      );
    }

    match /{path=**}/orders/{orderId} {
      allow list: if isSignedIn() && (
        resource.data.cafeId == getSelfData().cafeId ||
        getSelfData().role == 'SUPER_ADMIN'
      );
    }
  }
}
