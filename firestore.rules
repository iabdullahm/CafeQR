
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isCafeAdmin(cafeId) {
      let user = getUserData();
      return isSignedIn() && user.cafeId == cafeId && (user.role == 'OWNER' || user.role == 'MANAGER');
    }

    function isSuperAdmin() {
      return isSignedIn() && getUserData().role == 'SUPER_ADMIN';
    }

    // --- RULES ---

    match /plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow list: if isSuperAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    match /cafes/{cafeId} {
      allow get: if true;
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isCafeAdmin(cafeId) || isSuperAdmin();
    }

    match /cafes/{cafeId}/branches/{branchId} {
      allow read: if true;
      allow write: if isCafeAdmin(cafeId);
    }

    match /cafes/{cafeId}/branches/{branchId}/tables/{tableId} {
      allow read: if true;
      allow write: if isCafeAdmin(cafeId);
    }

    match /cafes/{cafeId}/orders/{orderId} {
      allow read: if isCafeAdmin(cafeId);
      allow create: if request.resource.data.cafeId == cafeId; // Public ordering
      allow update: if isCafeAdmin(cafeId);
    }

    match /cafes/{cafeId}/products/{productId} {
      allow read: if true;
      allow write: if isCafeAdmin(cafeId);
    }
    
    // Collection Group Queries for Tables (Requires cafeId field in documents)
    match /{path=**}/tables/{tableId} {
      allow list: if isSignedIn() && isCafeAdmin(resource.data.cafeId);
    }
  }
}
