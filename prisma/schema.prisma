// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum UserStatus {
  active
  suspended
  pending
}

enum CafeStatus {
  active
  trial
  expired
  suspended
  pending
  archived
}

enum SubscriptionStatus {
  trial
  active
  expired
  cancelled
  suspended
}

enum PaymentStatus {
  paid
  unpaid
  pending
  overdue
  refunded
}

enum OrderStatus {
  pending
  confirmed
  preparing
  ready
  completed
  cancelled
}

enum OrderType {
  dine_in
  car
  pickup
}

enum OrderSource {
  qr
  cashier
  admin
}

// --- Models ---

model User {
  id              BigInt     @id @default(autoincrement())
  uuid            String     @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName        String     @map("full_name")
  email           String     @unique
  phone           String?
  passwordHash    String     @map("password_hash")
  avatar          String?
  status          UserStatus @default(active)
  lastLoginAt     DateTime?  @map("last_login_at")
  emailVerifiedAt DateTime?  @map("email_verified_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")

  roles      UserRole[]
  ownedCafes Cafe[]     @relation("CafeOwner")
  cafeUsers  CafeUser[]

  @@index([status])
  @@map("users")
}

model Role {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique
  displayName String   @map("display_name")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique
  displayName String   @map("display_name")
  module      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId BigInt @map("user_id")
  roleId BigInt @map("role_id")

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       BigInt @map("role_id")
  permissionId BigInt @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Cafe {
  id               BigInt     @id @default(autoincrement())
  uuid             String     @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeCode         String     @unique @map("cafe_code")
  name             String
  slug             String     @unique
  logo             String?
  coverImage       String?    @map("cover_image")
  description      String?
  ownerUserId      BigInt?    @map("owner_user_id")
  phone            String?
  email            String?
  country          String?
  city             String?
  address          String?
  latitude         Decimal?   @db.Decimal(10, 8)
  longitude        Decimal?   @db.Decimal(11, 8)
  timezone         String     @default("UTC")
  currency         String     @default("USD")
  status           CafeStatus @default(active)
  onboardingStatus String     @default("pending") @map("onboarding_status")
  joinedAt         DateTime?  @map("joined_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  deletedAt        DateTime?  @map("deleted_at")

  owner           User?            @relation("CafeOwner", fields: [ownerUserId], references: [id])
  branches        CafeBranch[]
  cafeUsers       CafeUser[]
  subscriptions   Subscription[]
  tables          CafeTable[]
  categories      MenuCategory[]
  items           MenuItem[]
  customers       Customer[]
  orders          Order[]
  loyaltyAccounts LoyaltyAccount[]
  loyaltyProgram  LoyaltyProgram?

  @@index([status, city])
  @@map("cafes")
}

model CafeBranch {
  id           BigInt   @id @default(autoincrement())
  uuid         String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId       BigInt   @map("cafe_id")
  branchCode   String   @map("branch_code")
  name         String
  phone        String?
  email        String?
  city         String?
  address      String?
  latitude     Decimal? @db.Decimal(10, 8)
  longitude    Decimal? @db.Decimal(11, 8)
  status       String   @default("active")
  isMainBranch Boolean  @default(false) @map("is_main_branch")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  cafe       Cafe           @relation(fields: [cafeId], references: [id])
  cafeUsers  CafeUser[]
  tables     CafeTable[]
  categories MenuCategory[]
  items      MenuItem[]
  orders     Order[]

  @@map("cafe_branches")
}

model CafeUser {
  id        BigInt   @id @default(autoincrement())
  cafeId    BigInt   @map("cafe_id")
  userId    BigInt   @map("user_id")
  branchId  BigInt?  @map("branch_id")
  roleId    BigInt   @map("role_id")
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cafe   Cafe        @relation(fields: [cafeId], references: [id])
  user   User        @relation(fields: [userId], references: [id])
  branch CafeBranch? @relation(fields: [branchId], references: [id])

  @@map("cafe_users")
}

model Plan {
  id               BigInt   @id @default(autoincrement())
  uuid             String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  slug             String   @unique
  description      String?
  monthlyPrice     Decimal  @map("monthly_price") @db.Decimal(10, 3)
  yearlyPrice      Decimal  @map("yearly_price") @db.Decimal(10, 3)
  currency         String   @default("USD")
  billingCycleType String   @default("monthly") @map("billing_cycle_type")
  maxBranches      Int      @default(1) @map("max_branches")
  maxTables        Int      @default(10) @map("max_tables")
  maxProducts      Int      @default(50) @map("max_products")
  maxStaffUsers    Int      @default(3) @map("max_staff_users")
  trialDays        Int      @default(14) @map("trial_days")
  isPopular        Boolean  @default(false) @map("is_popular")
  status           String   @default("active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  features      PlanFeature[]
  subscriptions Subscription[]

  @@map("plans")
}

model PlanFeature {
  id           BigInt @id @default(autoincrement())
  planId       BigInt @map("plan_id")
  featureKey   String @map("feature_key")
  featureValue String @map("feature_value")

  plan Plan @relation(fields: [planId], references: [id])

  @@map("plan_features")
}

model Subscription {
  id               BigInt             @id @default(autoincrement())
  uuid             String             @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId           BigInt             @map("cafe_id")
  planId           BigInt             @map("plan_id")
  subscriptionType String             @map("subscription_type")
  startDate        DateTime           @map("start_date")
  endDate          DateTime           @map("end_date")
  nextBillingDate  DateTime?          @map("next_billing_date")
  trialStartDate   DateTime?          @map("trial_start_date")
  trialEndDate     DateTime?          @map("trial_end_date")
  amount           Decimal            @db.Decimal(10, 3)
  discountAmount   Decimal            @default(0) @map("discount_amount") @db.Decimal(10, 3)
  taxAmount        Decimal            @default(0) @map("tax_amount") @db.Decimal(10, 3)
  totalAmount      Decimal            @map("total_amount") @db.Decimal(10, 3)
  currency         String             @default("USD")
  status           SubscriptionStatus @default(active)
  paymentStatus    PaymentStatus      @default(pending) @map("payment_status")
  autoRenew        Boolean            @default(true) @map("auto_renew")
  cancelledAt      DateTime?          @map("cancelled_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  cafe Cafe @relation(fields: [cafeId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model CafeTable {
  id          BigInt   @id @default(autoincrement())
  uuid        String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId      BigInt   @map("cafe_id")
  branchId    BigInt   @map("branch_id")
  tableNumber String   @map("table_number")
  tableName   String?  @map("table_name")
  seatsCount  Int      @default(2) @map("seats_count")
  status      String   @default("available")
  qrCodeId    BigInt?  @map("qr_code_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cafe   Cafe       @relation(fields: [cafeId], references: [id])
  branch CafeBranch @relation(fields: [branchId], references: [id])
  qrCode QRCode?    @relation("TableQR", fields: [qrCodeId], references: [id])
  orders Order[]

  @@map("cafe_tables")
}

model QRCode {
  id            BigInt    @id @default(autoincrement())
  uuid          String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId        BigInt    @map("cafe_id")
  branchId      BigInt    @map("branch_id")
  tableId       BigInt?   @map("table_id")
  qrType        String    @map("qr_type")
  code          String    @unique
  token         String    @unique
  url           String
  imagePath     String?   @map("image_path")
  scanCount     Int       @default(0) @map("scan_count")
  lastScannedAt DateTime? @map("last_scanned_at")
  status        String    @default("active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tables   CafeTable[] @relation("TableQR")
  scanLogs QRScanLog[]

  @@map("qr_codes")
}

model QRScanLog {
  id         BigInt   @id @default(autoincrement())
  qrCodeId   BigInt   @map("qr_code_id")
  cafeId     BigInt?  @map("cafe_id")
  branchId   BigInt?  @map("branch_id")
  tableId    BigInt?  @map("table_id")
  customerIp String?  @map("customer_ip")
  deviceType String?  @map("device_type")
  browser    String?
  os         String?
  scannedAt  DateTime @default(now()) @map("scanned_at")

  qrCode QRCode @relation(fields: [qrCodeId], references: [id])

  @@map("qr_scan_logs")
}

model MenuCategory {
  id          BigInt   @id @default(autoincrement())
  uuid        String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId      BigInt   @map("cafe_id")
  branchId    BigInt?  @map("branch_id")
  name        String
  description String?
  image       String?
  sortOrder   Int      @default(0) @map("sort_order")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cafe   Cafe        @relation(fields: [cafeId], references: [id])
  branch CafeBranch? @relation(fields: [branchId], references: [id])
  items  MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id              BigInt   @id @default(autoincrement())
  uuid            String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId          BigInt   @map("cafe_id")
  branchId        BigInt?  @map("branch_id")
  categoryId      BigInt   @map("category_id")
  sku             String?
  name            String
  description     String?
  image           String?
  price           Decimal  @db.Decimal(10, 3)
  costPrice       Decimal? @map("cost_price") @db.Decimal(10, 3)
  preparationTime Int?     @map("preparation_time")
  calories        Int?
  isAvailable     Boolean  @default(true) @map("is_available")
  isFeatured      Boolean  @default(false) @map("is_featured")
  status          String   @default("active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  cafe       Cafe             @relation(fields: [cafeId], references: [id])
  branch     CafeBranch?      @relation(fields: [branchId], references: [id])
  category   MenuCategory     @relation(fields: [categoryId], references: [id])
  options    MenuItemOption[]
  orderItems OrderItem[]

  @@map("menu_items")
}

model MenuItemOption {
  id         BigInt   @id @default(autoincrement())
  menuItemId BigInt   @map("menu_item_id")
  name       String
  type       String   @default("single")
  isRequired Boolean  @default(false) @map("is_required")
  minSelect  Int      @default(0) @map("min_select")
  maxSelect  Int      @default(1) @map("max_select")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  menuItem MenuItem              @relation(fields: [menuItemId], references: [id])
  values   MenuItemOptionValue[]

  @@map("menu_item_options")
}

model MenuItemOptionValue {
  id         BigInt   @id @default(autoincrement())
  optionId   BigInt   @map("option_id")
  valueName  String   @map("value_name")
  extraPrice Decimal  @default(0) @map("extra_price") @db.Decimal(10, 3)
  sortOrder  Int      @default(0) @map("sort_order")
  status     String   @default("active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  option MenuItemOption @relation(fields: [optionId], references: [id])

  @@map("menu_item_option_values")
}

model Customer {
  id             BigInt   @id @default(autoincrement())
  uuid           String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId         BigInt   @map("cafe_id")
  name           String
  phone          String?
  email          String?
  carPlateNumber String?  @map("car_plate_number")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  cafe           Cafe            @relation(fields: [cafeId], references: [id])
  orders         Order[]
  loyaltyAccount LoyaltyAccount? @relation("CustomerLoyalty")

  @@map("customers")
}

model Order {
  id             BigInt      @id @default(autoincrement())
  uuid           String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId         BigInt      @map("cafe_id")
  branchId       BigInt?     @map("branch_id")
  tableId        BigInt?     @map("table_id")
  customerId     BigInt?     @map("customer_id")
  orderNumber    String      @unique @map("order_number")
  orderType      OrderType   @map("order_type")
  source         OrderSource @map("source")
  subtotal       Decimal     @db.Decimal(10, 3)
  discountAmount Decimal     @default(0) @map("discount_amount") @db.Decimal(10, 3)
  taxAmount      Decimal     @default(0) @map("tax_amount") @db.Decimal(10, 3)
  totalAmount    Decimal     @map("total_amount") @db.Decimal(10, 3)
  notes          String?
  status         OrderStatus @default(pending)
  paymentStatus  String      @default("unpaid") @map("payment_status")
  placedAt       DateTime    @default(now()) @map("placed_at")
  completedAt    DateTime?   @map("completed_at")
  cancelledAt    DateTime?   @map("cancelled_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  cafe     Cafe        @relation(fields: [cafeId], references: [id])
  branch   CafeBranch? @relation(fields: [branchId], references: [id])
  table    CafeTable?  @relation(fields: [tableId], references: [id])
  customer Customer?   @relation(fields: [customerId], references: [id])
  items    OrderItem[]

  @@index([cafeId, status, placedAt])
  @@map("orders")
}

model OrderItem {
  id         BigInt   @id @default(autoincrement())
  orderId    BigInt   @map("order_id")
  menuItemId BigInt   @map("menu_item_id")
  itemName   String   @map("item_name")
  unitPrice  Decimal  @map("unit_price") @db.Decimal(10, 3)
  quantity   Int
  totalPrice Decimal  @map("total_price") @db.Decimal(10, 3)
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  order    Order             @relation(fields: [orderId], references: [id])
  menuItem MenuItem          @relation(fields: [menuItemId], references: [id])
  options  OrderItemOption[]

  @@map("order_items")
}

model OrderItemOption {
  id          BigInt  @id @default(autoincrement())
  orderItemId BigInt  @map("order_item_id")
  optionName  String  @map("option_name")
  optionValue String  @map("option_value")
  extraPrice  Decimal @map("extra_price") @db.Decimal(10, 3)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  @@map("order_item_options")
}

model LoyaltyProgram {
  id                 BigInt   @id @default(autoincrement())
  cafeId             BigInt   @unique @map("cafe_id")
  status             String   @default("active")
  cupsRequired       Int      @default(5) @map("cups_required")
  rewardItem         String   @default("any_coffee") @map("reward_item")
  countOnlyCoffee    Boolean  @default(true) @map("count_only_coffee")
  eligibleCategories String   @default("hot,cold") @map("eligible_categories")
  autoReset          Boolean  @default(true) @map("auto_reset")
  branchRules        String   @default("all") @map("branch_rules")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  cafe Cafe @relation(fields: [cafeId], references: [id])

  @@map("loyalty_programs")
}

model LoyaltyAccount {
  id              BigInt   @id @default(autoincrement())
  customerId      BigInt   @unique @map("customer_id")
  cafeId          BigInt   @map("cafe_id")
  cups            Int      @default(0)
  rewardsEarned   Int      @default(0) @map("rewards_earned")
  rewardsRedeemed Int      @default(0) @map("rewards_redeemed")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  customer     Customer             @relation("CustomerLoyalty", fields: [customerId], references: [id])
  cafe         Cafe                 @relation(fields: [cafeId], references: [id])
  transactions LoyaltyTransaction[]

  @@map("loyalty_accounts")
}

model LoyaltyTransaction {
  id         BigInt   @id @default(autoincrement())
  accountId  BigInt   @map("account_id")
  action     String   @default("Earned")
  cupsCount  Int      @map("cups_count")
  rewardItem String?  @map("reward_item")
  status     String   @default("Completed")
  createdAt  DateTime @default(now()) @map("created_at")

  account LoyaltyAccount @relation(fields: [accountId], references: [id])

  @@map("loyalty_transactions")
}

model Invoice {
  id             BigInt   @id @default(autoincrement())
  uuid           String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId BigInt   @map("subscription_id")
  invoiceNumber  String   @unique @map("invoice_number")
  amount         Decimal  @db.Decimal(10, 3)
  status         String   @default("unpaid")
  dueDate        DateTime @map("due_date")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("invoices")
}

model Payment {
  id            BigInt   @id @default(autoincrement())
  uuid          String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId     BigInt   @map("invoice_id")
  amount        Decimal  @db.Decimal(10, 3)
  method        String
  transactionId String?  @map("transaction_id")
  status        String   @default("pending")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("payments")
}

model SupportTicket {
  id           BigInt   @id @default(autoincrement())
  uuid         String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId       BigInt   @map("cafe_id")
  ticketNumber String   @unique @map("ticket_number")
  subject      String
  priority     String   @default("medium")
  status       String   @default("open")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  messages SupportTicketMessage[]

  @@map("support_tickets")
}

model SupportTicketMessage {
  id        BigInt   @id @default(autoincrement())
  ticketId  BigInt   @map("ticket_id")
  userId    BigInt?  @map("user_id")
  message   String
  isAdmin   Boolean  @default(false) @map("is_admin")
  createdAt DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id])

  @@map("support_ticket_messages")
}

model Notification {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt?  @map("user_id")
  cafeId    BigInt?  @map("cafe_id")
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  type      String   @default("info")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model ActivityLog {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt?  @map("user_id")
  action    String
  module    String
  details   Json?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("activity_logs")
}

model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  group     String   @default("general")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}
