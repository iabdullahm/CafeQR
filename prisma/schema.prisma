
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================
// 1) USERS / ROLES / PERMISSIONS
// =========================================================

model User {
  id                BigInt      @id @default(autoincrement())
  uuid              String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName          String      @map("full_name")
  email             String      @unique
  phone             String?
  passwordHash      String      @map("password_hash")
  avatar            String?
  status            String      @default("pending") // 'active', 'suspended', 'pending'
  lastLoginAt       DateTime?   @map("last_login_at")
  emailVerifiedAt   DateTime?   @map("email_verified_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  deletedAt         DateTime?   @map("deleted_at")

  roles             UserRole[]
  ownedCafes        Cafe[]      @relation("CafeOwner")
  cafeUsers         CafeUser[]
  supportTickets    SupportTicket[] @relation("CreatedBy")
  assignedTickets   SupportTicket[] @relation("AssignedTo")
  ticketMessages    SupportTicketMessage[]
  notifications     Notification[]
  activityLogs      ActivityLog[]

  @@map("users")
  @@index([email])
  @@index([status])
}

model Role {
  id              BigInt            @id @default(autoincrement())
  name            String            @unique
  displayName     String            @map("display_name")
  description     String?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  permissions     RolePermission[]
  users           UserRole[]
  cafeUsers       CafeUser[]

  @@map("roles")
}

model Permission {
  id              BigInt            @id @default(autoincrement())
  name            String            @unique
  displayName     String            @map("display_name")
  module          String
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  roles           RolePermission[]

  @@map("permissions")
}

model UserRole {
  id        BigInt @id @default(autoincrement())
  userId    BigInt @map("user_id")
  roleId    BigInt @map("role_id")

  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id            BigInt      @id @default(autoincrement())
  roleId        BigInt      @map("role_id")
  permissionId  BigInt      @map("permission_id")

  role          Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// =========================================================
// 2) CAFES / BRANCHES / CAFE USERS
// =========================================================

model Cafe {
  id                BigInt          @id @default(autoincrement())
  uuid              String          @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeCode          String          @unique @map("cafe_code")
  name              String
  slug              String          @unique
  logo              String?
  coverImage        String?         @map("cover_image")
  description       String?
  ownerUserId       BigInt?         @map("owner_user_id")
  phone             String?
  email             String?
  country           String?
  city              String?
  address           String?
  latitude          Decimal?        @db.Decimal(10, 7)
  longitude         Decimal?        @db.Decimal(10, 7)
  timezone          String          @default("Asia/Muscat")
  currency          String          @default("OMR")
  status            String          @default("pending") // 'active', 'trial', 'expired', 'suspended', 'pending', 'archived'
  onboardingStatus  String          @default("not_started") @map("onboarding_status") // 'not_started', 'in_progress', 'completed'
  joinedAt          DateTime?       @map("joined_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  deletedAt         DateTime?       @map("deleted_at")

  owner             User?           @relation("CafeOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  branches          CafeBranch[]
  cafeUsers         CafeUser[]
  subscriptions     Subscription[]
  subscriptionHistory SubscriptionHistory[]
  qrCodes           QRCode[]
  tables            CafeTable[]
  scanLogs          QRScanLog[]
  menuCategories    MenuCategory[]
  menuItems         MenuItem[]
  customers         Customer[]
  orders            Order[]
  loyaltyProgram    LoyaltyProgram?
  loyaltyAccounts   LoyaltyAccount[]
  loyaltyTransactions LoyaltyTransaction[]
  invoices          Invoice[]
  payments          Payment[]
  supportTickets    SupportTicket[]
  notifications     Notification[]
  activityLogs      ActivityLog[]

  @@map("cafes")
  @@index([ownerUserId])
  @@index([status])
  @@index([city])
}

model CafeBranch {
  id            BigInt      @id @default(autoincrement())
  uuid          String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId        BigInt      @map("cafe_id")
  branchCode    String      @map("branch_code")
  name          String
  phone         String?
  email         String?
  city          String?
  address       String?
  latitude      Decimal?    @db.Decimal(10, 7)
  longitude     Decimal?    @db.Decimal(10, 7)
  status        String      @default("active") // 'active', 'inactive', 'suspended'
  isMainBranch  Boolean     @default(false) @map("is_main_branch")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  cafe          Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  cafeUsers     CafeUser[]
  qrCodes       QRCode[]
  tables        CafeTable[]
  scanLogs      QRScanLog[]
  menuCategories MenuCategory[]
  menuItems      MenuItem[]
  orders        Order[]

  @@unique([cafeId, branchCode])
  @@map("cafe_branches")
  @@index([cafeId])
}

model CafeUser {
  id        BigInt      @id @default(autoincrement())
  cafeId    BigInt      @map("cafe_id")
  userId    BigInt      @map("user_id")
  branchId  BigInt?     @map("branch_id")
  roleId    BigInt?     @map("role_id")
  status    String      @default("active") // 'active', 'inactive', 'suspended'
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  cafe      Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch    CafeBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  role      Role?       @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([cafeId, userId, branchId])
  @@map("cafe_users")
  @@index([cafeId])
  @@index([userId])
}

// =========================================================
// 3) PLANS / SUBSCRIPTIONS
// =========================================================

model Plan {
  id              BigInt          @id @default(autoincrement())
  uuid            String          @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String          @unique
  slug            String          @unique
  description     String?
  monthlyPrice    Decimal         @default(0) @map("monthly_price") @db.Decimal(12, 3)
  yearlyPrice     Decimal         @default(0) @map("yearly_price") @db.Decimal(12, 3)
  currency        String          @default("OMR")
  billingCycleType String         @default("monthly") @map("billing_cycle_type") // 'monthly', 'yearly', 'custom'
  maxBranches     Int             @default(1) @map("max_branches")
  maxTables       Int             @default(0) @map("max_tables")
  maxProducts     Int             @default(0) @map("max_products")
  maxStaffUsers   Int             @default(0) @map("max_staff_users")
  trialDays       Int             @default(0) @map("trial_days")
  isPopular       Boolean         @default(false) @map("is_popular")
  status          String          @default("active") // 'active', 'inactive'
  sortOrder       Int             @default(0) @map("sort_order")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  features        PlanFeature[]
  subscriptions   Subscription[]
  historyFrom     SubscriptionHistory[] @relation("OldPlan")
  historyTo       SubscriptionHistory[] @relation("NewPlan")

  @@map("plans")
}

model PlanFeature {
  id          BigInt      @id @default(autoincrement())
  planId      BigInt      @map("plan_id")
  featureKey  String      @map("feature_key")
  featureValue String     @map("feature_value")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  plan        Plan        @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@map("plan_features")
}

model Subscription {
  id                BigInt      @id @default(autoincrement())
  uuid              String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId            BigInt      @map("cafe_id")
  planId            BigInt      @map("plan_id")
  subscriptionType  String      @map("subscription_type") // 'monthly', 'yearly', 'trial', 'custom'
  startDate         DateTime    @map("start_date") @db.Date
  endDate           DateTime    @map("end_date") @db.Date
  nextBillingDate   DateTime?   @map("next_billing_date") @db.Date
  trialStartDate    DateTime?   @map("trial_start_date") @db.Date
  trialEndDate      DateTime?   @map("trial_end_date") @db.Date
  amount            Decimal     @default(0) @db.Decimal(12, 3)
  discountAmount    Decimal     @default(0) @map("discount_amount") @db.Decimal(12, 3)
  taxAmount         Decimal     @default(0) @map("tax_amount") @db.Decimal(12, 3)
  totalAmount       Decimal     @default(0) @map("total_amount") @db.Decimal(12, 3)
  currency          String      @default("OMR")
  status            String      // 'trial', 'active', 'expired', 'cancelled', 'suspended'
  paymentStatus     String      @default("unpaid") @map("payment_status") // 'paid', 'unpaid', 'pending', 'overdue', 'refunded'
  autoRenew         Boolean     @default(false) @map("auto_renew")
  cancelledAt       DateTime?   @map("cancelled_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  cafe              Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  plan              Plan        @relation(fields: [planId], references: [id], onDelete: Restrict)
  histories         SubscriptionHistory[]
  invoices          Invoice[]
  payments          Payment[]

  @@map("subscriptions")
  @@index([cafeId])
  @@index([planId])
  @@index([status])
  @@index([endDate])
}

model SubscriptionHistory {
  id              BigInt      @id @default(autoincrement())
  subscriptionId  BigInt      @map("subscription_id")
  cafeId          BigInt      @map("cafe_id")
  oldPlanId       BigInt?     @map("old_plan_id")
  newPlanId       BigInt?     @map("new_plan_id")
  actionType      String      @map("action_type") // 'created', 'upgraded', 'downgraded', 'renewed', 'cancelled', 'expired'
  amount          Decimal     @default(0) @db.Decimal(12, 3)
  notes           String?
  changedBy       BigInt?     @map("changed_by")
  createdAt       DateTime    @default(now()) @map("created_at")

  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  cafe            Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  oldPlan         Plan?       @relation("OldPlan", fields: [oldPlanId], references: [id], onDelete: SetNull)
  newPlan         Plan?       @relation("NewPlan", fields: [newPlanId], references: [id], onDelete: SetNull)

  @@map("subscription_histories")
}

// =========================================================
// 4) TABLES / QR
// =========================================================

model QRCode {
  id              BigInt      @id @default(autoincrement())
  uuid            String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId          BigInt      @map("cafe_id")
  branchId        BigInt?     @map("branch_id")
  tableId         BigInt?     @unique @map("table_id")
  qrType          String      @map("qr_type") // 'table', 'car', 'general_menu'
  code            String      @unique
  token           String      @unique
  url             String
  imagePath       String?     @map("image_path")
  scanCount       Int         @default(0) @map("scan_count")
  lastScannedAt   DateTime?   @map("last_scanned_at")
  status          String      @default("active") // 'active', 'inactive'
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  cafe            Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  branch          CafeBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  table           CafeTable?  @relation("TableQR", fields: [tableId], references: [id], onDelete: SetNull)
  scanLogs        QRScanLog[]

  @@map("qr_codes")
  @@index([cafeId])
  @@index([branchId])
  @@index([tableId])
}

model CafeTable {
  id            BigInt      @id @default(autoincrement())
  uuid          String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId        BigInt      @map("cafe_id")
  branchId      BigInt?     @map("branch_id")
  tableNumber   String      @map("table_number")
  tableName     String?     @map("table_name")
  seatsCount    Int         @default(0) @map("seats_count")
  qrCodeId      BigInt?     @unique @map("qr_code_id")
  status        String      @default("active") // 'active', 'inactive', 'maintenance'
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  cafe          Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  branch        CafeBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  qrCode        QRCode?     @relation("TableQR")
  scanLogs      QRScanLog[]
  orders        Order[]

  @@unique([cafeId, branchId, tableNumber])
  @@map("cafe_tables")
  @@index([cafeId])
  @@index([branchId])
}

model QRScanLog {
  id          BigInt      @id @default(autoincrement())
  qrCodeId    BigInt      @map("qr_code_id")
  cafeId      BigInt      @map("cafe_id")
  branchId    BigInt?     @map("branch_id")
  tableId     BigInt?     @map("table_id")
  customerIp  String?     @map("customer_ip")
  deviceType  String?     @map("device_type")
  browser     String?
  os          String?
  scannedAt   DateTime    @default(now()) @map("scanned_at")

  qrCode      QRCode      @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  cafe        Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  branch      CafeBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  table       CafeTable?  @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@map("qr_scan_logs")
}

// =========================================================
// 5) MENU MANAGEMENT
// =========================================================

model MenuCategory {
  id            BigInt      @id @default(autoincrement())
  uuid          String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId        BigInt      @map("cafe_id")
  branchId      BigInt?     @map("branch_id")
  name          String
  description   String?
  image         String?
  sortOrder     Int         @default(0) @map("sort_order")
  status        String      @default("active") // 'active', 'inactive'
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  cafe          Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  branch        CafeBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  menuItems     MenuItem[]

  @@map("menu_categories")
  @@index([cafeId])
}

model MenuItem {
  id              BigInt      @id @default(autoincrement())
  uuid            String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId          BigInt      @map("cafe_id")
  branchId        BigInt?     @map("branch_id")
  categoryId      BigInt?     @map("category_id")
  sku             String?
  name            String
  description     String?
  image           String?
  price           Decimal     @default(0) @db.Decimal(12, 3)
  costPrice       Decimal     @default(0) @map("cost_price") @db.Decimal(12, 3)
  preparationTime Int?        @map("preparation_time")
  calories        Int?
  isAvailable     Boolean     @default(true) @map("is_available")
  isFeatured      Boolean     @default(false) @map("is_featured")
  status          String      @default("active") // 'active', 'inactive', 'out_of_stock'
  sortOrder       Int         @default(0) @map("sort_order")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  cafe            Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  branch          CafeBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  category        MenuCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  options         MenuItemOption[]
  orderItems      OrderItem[]

  @@map("menu_items")
  @@index([cafeId])
  @@index([categoryId])
}

model MenuItemOption {
  id          BigInt      @id @default(autoincrement())
  menuItemId  BigInt      @map("menu_item_id")
  name        String
  type        String      // 'single', 'multiple'
  isRequired  Boolean     @default(false) @map("is_required")
  minSelect   Int         @default(0) @map("min_select")
  maxSelect   Int         @default(1) @map("max_select")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  menuItem    MenuItem    @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  values      MenuItemOptionValue[]

  @@map("menu_item_options")
}

model MenuItemOptionValue {
  id          BigInt      @id @default(autoincrement())
  optionId    BigInt      @map("option_id")
  valueName   String      @map("value_name")
  extraPrice  Decimal     @default(0) @map("extra_price") @db.Decimal(12, 3)
  sortOrder   Int         @default(0) @map("sort_order")
  status      String      @default("active") // 'active', 'inactive'
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  option      MenuItemOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@map("menu_item_option_values")
}

// =========================================================
// 6) CUSTOMERS / ORDERS
// =========================================================

model Customer {
  id              BigInt      @id @default(autoincrement())
  uuid            String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId          BigInt      @map("cafe_id")
  name            String?
  phone           String?
  email           String?
  carPlateNumber  String?     @map("car_plate_number")
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  cafe            Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  orders          Order[]
  loyaltyAccount  LoyaltyAccount?
  loyaltyTransactions LoyaltyTransaction[]

  @@map("customers")
  @@index([cafeId])
}

model Order {
  id            BigInt      @id @default(autoincrement())
  uuid          String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId        BigInt      @map("cafe_id")
  branchId      BigInt?     @map("branch_id")
  tableId       BigInt?     @map("table_id")
  customerId    BigInt?     @map("customer_id")
  orderNumber   String      @unique @map("order_number")
  orderType     String      @map("order_type") // 'dine_in', 'car', 'pickup'
  source        String      // 'qr', 'cashier', 'admin'
  subtotal      Decimal     @default(0) @db.Decimal(12, 3)
  discountAmount Decimal    @default(0) @map("discount_amount") @db.Decimal(12, 3)
  taxAmount     Decimal     @default(0) @map("tax_amount") @db.Decimal(12, 3)
  totalAmount   Decimal     @default(0) @map("total_amount") @db.Decimal(12, 3)
  notes         String?
  status        String      // 'pending', 'confirmed', 'preparing', 'ready', 'completed', 'cancelled'
  paymentStatus String      @default("unpaid") @map("payment_status") // 'unpaid', 'paid', 'refunded'
  placedAt      DateTime    @default(now()) @map("placed_at")
  completedAt   DateTime?   @map("completed_at")
  cancelledAt   DateTime?   @map("cancelled_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  cafe          Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  branch        CafeBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  table         CafeTable?  @relation(fields: [tableId], references: [id], onDelete: SetNull)
  customer      Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  loyaltyTransactions LoyaltyTransaction[]

  @@map("orders")
  @@index([cafeId])
  @@index([branchId])
  @@index([tableId])
  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([placedAt])
}

model OrderItem {
  id            BigInt      @id @default(autoincrement())
  orderId       BigInt      @map("order_id")
  menuItemId    BigInt?     @map("menu_item_id")
  itemName      String      @map("item_name")
  unitPrice     Decimal     @default(0) @map("unit_price") @db.Decimal(12, 3)
  quantity      Int         @default(1)
  totalPrice    Decimal     @default(0) @map("total_price") @db.Decimal(12, 3)
  notes         String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem      MenuItem?   @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  options       OrderItemOption[]

  @@map("order_items")
  @@index([orderId])
}

model OrderItemOption {
  id            BigInt      @id @default(autoincrement())
  orderItemId   BigInt      @map("order_item_id")
  optionName    String      @map("option_name")
  optionValue   String      @map("option_value")
  extraPrice    Decimal     @default(0) @map("extra_price") @db.Decimal(12, 3)
  createdAt     DateTime    @default(now()) @map("created_at")

  orderItem     OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("order_item_options")
}

// =========================================================
// 7) LOYALTY
// =========================================================

model LoyaltyProgram {
  id                BigInt      @id @default(autoincrement())
  cafeId            BigInt      @unique @map("cafe_id")
  isEnabled         Boolean     @default(false) @map("is_enabled")
  pointsPerCurrency Decimal     @default(1) @map("points_per_currency") @db.Decimal(10, 2)
  minimumRedeemPoints Int       @default(0) @map("minimum_redeem_points")
  redeemValue       Decimal     @default(0) @map("redeem_value") @db.Decimal(12, 3)
  birthdayRewardPoints Int      @default(0) @map("birthday_reward_points")
  status            String      @default("active") // 'active', 'inactive'
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  cafe              Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@map("loyalty_programs")
}

model LoyaltyAccount {
  id            BigInt      @id @default(autoincrement())
  cafeId        BigInt      @map("cafe_id")
  customerId    BigInt      @map("customer_id")
  totalPoints   Int         @default(0) @map("total_points")
  totalEarned   Int         @default(0) @map("total_earned")
  totalRedeemed Int         @default(0) @map("total_redeemed")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  cafe          Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  customer      Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([cafeId, customerId])
  @@map("loyalty_accounts")
  @@index([cafeId])
}

model LoyaltyTransaction {
  id              BigInt      @id @default(autoincrement())
  cafeId          BigInt      @map("cafe_id")
  customerId      BigInt      @map("customer_id")
  orderId         BigInt?     @map("order_id")
  transactionType String      @map("transaction_type") // 'earned', 'redeemed', 'adjusted', 'expired'
  points          Int
  description     String?
  createdAt       DateTime    @default(now()) @map("created_at")

  cafe            Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order           Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@map("loyalty_transactions")
  @@index([customerId])
}

// =========================================================
// 8) INVOICES / PAYMENTS
// =========================================================

model Invoice {
  id              BigInt      @id @default(autoincrement())
  uuid            String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId          BigInt      @map("cafe_id")
  subscriptionId  BigInt?     @map("subscription_id")
  invoiceNumber   String      @unique @map("invoice_number")
  amount          Decimal     @default(0) @db.Decimal(12, 3)
  taxAmount       Decimal     @default(0) @map("tax_amount") @db.Decimal(12, 3)
  discountAmount  Decimal     @default(0) @map("discount_amount") @db.Decimal(12, 3)
  totalAmount     Decimal     @default(0) @map("total_amount") @db.Decimal(12, 3)
  currency        String      @default("OMR")
  issueDate       DateTime    @map("issue_date") @db.Date
  dueDate         DateTime?   @map("due_date") @db.Date
  status          String      // 'draft', 'unpaid', 'paid', 'overdue', 'cancelled'
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  cafe            Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payments        Payment[]

  @@map("invoices")
  @@index([cafeId])
  @@index([subscriptionId])
  @@index([status])
}

model Payment {
  id                BigInt      @id @default(autoincrement())
  uuid              String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId            BigInt      @map("cafe_id")
  invoiceId         BigInt?     @map("invoice_id")
  subscriptionId    BigInt?     @map("subscription_id")
  paymentReference  String?     @map("payment_reference")
  paymentMethod     String      @map("payment_method") // 'cash', 'bank_transfer', 'card', 'online'
  amount            Decimal     @default(0) @db.Decimal(12, 3)
  currency          String      @default("OMR")
  paymentDate       DateTime?   @map("payment_date")
  status            String      // 'pending', 'completed', 'failed', 'refunded'
  gatewayResponse   String?     @map("gateway_response")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  cafe            Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  invoice         Invoice?    @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@map("payments")
  @@index([cafeId])
  @@index([invoiceId])
  @@index([subscriptionId])
  @@index([status])
}

// =========================================================
// 9) SUPPORT / NOTIFICATIONS
// =========================================================

model SupportTicket {
  id            BigInt      @id @default(autoincrement())
  uuid          String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId        BigInt      @map("cafe_id")
  createdBy     BigInt?     @map("created_by")
  assignedTo    BigInt?     @map("assigned_to")
  ticketNumber  String      @unique @map("ticket_number")
  subject       String
  description   String?
  priority      String      // 'low', 'medium', 'high', 'critical'
  status        String      // 'open', 'in_progress', 'resolved', 'closed'
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  closedAt      DateTime?   @map("closed_at")

  cafe          Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  creator       User?       @relation("CreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  assignee      User?       @relation("AssignedTo", fields: [assignedTo], references: [id], onDelete: SetNull)
  messages      SupportTicketMessage[]

  @@map("support_tickets")
  @@index([cafeId])
  @@index([status])
}

model SupportTicketMessage {
  id          BigInt      @id @default(autoincrement())
  ticketId    BigInt      @map("ticket_id")
  senderId    BigInt?     @map("sender_id")
  message     String
  isInternal  Boolean     @default(false) @map("is_internal")
  createdAt   DateTime    @default(now()) @map("created_at")

  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender      User?         @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@map("support_ticket_messages")
  @@index([ticketId])
}

model Notification {
  id        BigInt      @id @default(autoincrement())
  userId    BigInt?     @map("user_id")
  cafeId    BigInt?     @map("cafe_id")
  title     String
  message   String
  type      String      // 'system', 'billing', 'subscription', 'support', 'order'
  isRead    Boolean     @default(false) @map("is_read")
  readAt    DateTime?   @map("read_at")
  createdAt DateTime    @default(now()) @map("created_at")

  user      User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cafe      Cafe?       @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@map("notifications")
  @@index([userId])
  @@index([cafeId])
  @@index([isRead])
}

// =========================================================
// 10) ACTIVITY LOGS / SETTINGS
// =========================================================

model ActivityLog {
  id          BigInt      @id @default(autoincrement())
  userId      BigInt?     @map("user_id")
  cafeId      BigInt?     @map("cafe_id")
  module      String
  action      String
  description String?
  ipAddress   String?     @map("ip_address")
  userAgent   String?     @map("user_agent")
  createdAt   DateTime    @default(now()) @map("created_at")

  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  cafe        Cafe?       @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
  @@index([userId])
  @@index([cafeId])
  @@index([module])
  @@index([createdAt])
}

model SystemSetting {
  id            BigInt      @id @default(autoincrement())
  settingKey    String      @unique @map("setting_key")
  settingValue  String?     @map("setting_value")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("system_settings")
}
