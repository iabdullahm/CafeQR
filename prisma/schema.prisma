// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id           BigInt           @id @default(autoincrement())
  name         String           @unique @db.VarChar(100)
  displayName  String           @map("display_name") @db.VarChar(150)
  description  String?          @db.Text
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  permissions  RolePermission[]
  userRoles    UserRole[]
  cafeUsers    CafeUser[]

  @@map("roles")
}

model Permission {
  id           BigInt           @id @default(autoincrement())
  name         String           @unique @db.VarChar(100)
  displayName  String           @map("display_name") @db.VarChar(150)
  module       String           @db.VarChar(100)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  roles        RolePermission[]

  @@map("permissions")
}

model User {
  id               BigInt           @id @default(autoincrement())
  uuid             String           @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName         String           @map("full_name") @db.VarChar(150)
  email            String           @unique @db.VarChar(150)
  phone            String?          @db.VarChar(30)
  passwordHash     String           @map("password_hash") @db.Text
  avatar           String?          @db.Text
  status           String           @default("pending") @db.VarChar(30)
  lastLoginAt      DateTime?        @map("last_login_at")
  emailVerifiedAt  DateTime?        @map("email_verified_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  deletedAt        DateTime?        @map("deleted_at")
  userRoles        UserRole[]
  ownedCafes       Cafe[]           @relation("CafeOwner")
  cafeUsers        CafeUser[]
  supportTickets   SupportTicket[]  @relation("CreatedBy")
  assignedTickets  SupportTicket[]  @relation("AssignedTo")
  ticketMessages   SupportTicketMessage[]
  notifications    Notification[]
  activityLogs     ActivityLog[]

  @@map("users")
}

model RolePermission {
  id           BigInt     @id @default(autoincrement())
  roleId       BigInt     @map("role_id")
  permissionId BigInt     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id      BigInt @id @default(autoincrement())
  userId  BigInt @map("user_id")
  roleId  BigInt @map("role_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Cafe {
  id                BigInt           @id @default(autoincrement())
  uuid              String           @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeCode          String           @unique @map("cafe_code") @db.VarChar(50)
  name              String           @db.VarChar(150)
  slug              String           @unique @db.VarChar(180)
  logo              String?          @db.Text
  ownerUserId       BigInt?          @map("owner_user_id")
  owner             User?            @relation("CafeOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  city              String           @db.VarChar(100)
  status            String           @default("pending") @db.VarChar(30)
  currency          String           @default("OMR") @db.VarChar(10)
  joinedAt          DateTime?        @map("joined_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  branches          CafeBranch[]
  cafeUsers         CafeUser[]
  subscriptions     Subscription[]
  orders            Order[]
  supportTickets    SupportTicket[]
  notifications     Notification[]
  activityLogs      ActivityLog[]

  @@map("cafes")
}

model CafeBranch {
  id           BigInt      @id @default(autoincrement())
  uuid         String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId       BigInt      @map("cafe_id")
  branchCode   String      @map("branch_code") @db.VarChar(50)
  name         String      @db.VarChar(150)
  city         String?     @db.VarChar(100)
  status       String      @default("active") @db.VarChar(30)
  isMainBranch Boolean     @default(false) @map("is_main_branch")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  cafe         Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  cafeUsers    CafeUser[]
  orders       Order[]

  @@unique([cafeId, branchCode])
  @@map("cafe_branches")
}

model CafeUser {
  id        BigInt      @id @default(autoincrement())
  cafeId    BigInt      @map("cafe_id")
  userId    BigInt      @map("user_id")
  branchId  BigInt?     @map("branch_id")
  roleId    BigInt?     @map("role_id")
  status    String      @default("active") @db.VarChar(30)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  cafe      Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch    CafeBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  role      Role?       @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([cafeId, userId, branchId])
  @@map("cafe_users")
}

model Subscription {
  id               BigInt     @id @default(autoincrement())
  uuid             String     @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId           BigInt     @map("cafe_id")
  planId           String     @map("plan_id")
  subscriptionType String     @map("subscription_type") @db.VarChar(20)
  startDate        DateTime   @map("start_date") @db.Date
  endDate          DateTime   @map("end_date") @db.Date
  amount           Decimal    @db.Decimal(12, 3)
  totalAmount      Decimal    @map("total_amount") @db.Decimal(12, 3)
  currency         String     @default("OMR") @db.VarChar(10)
  status           String     @db.VarChar(20)
  paymentStatus    String     @default("unpaid") @map("payment_status") @db.VarChar(20)
  autoRenew        Boolean    @default(false) @map("auto_renew")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  cafe             Cafe       @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Order {
  id            BigInt      @id @default(autoincrement())
  uuid          String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId        BigInt      @map("cafe_id")
  branchId      BigInt?     @map("branch_id")
  orderNumber   String      @unique @map("order_number") @db.VarChar(50)
  orderType     String      @map("order_type") @db.VarChar(20)
  source        String      @db.VarChar(20)
  totalAmount   Decimal     @map("total_amount") @db.Decimal(12, 3)
  status        String      @db.VarChar(20)
  paymentStatus String      @default("unpaid") @map("payment_status") @db.VarChar(20)
  placedAt      DateTime    @default(now()) @map("placed_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  cafe          Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  branch        CafeBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@map("orders")
}

model SupportTicket {
  id           BigInt     @id @default(autoincrement())
  uuid         String     @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cafeId       BigInt     @map("cafe_id")
  createdBy    BigInt?    @map("created_by")
  assignedTo   BigInt?    @map("assigned_to")
  ticketNumber String     @unique @map("ticket_number") @db.VarChar(50)
  subject      String     @db.VarChar(255)
  priority     String     @db.VarChar(20)
  status       String     @db.VarChar(20)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  cafe         Cafe       @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  creator      User?      @relation("CreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  assignee     User?      @relation("AssignedTo", fields: [assignedTo], references: [id], onDelete: SetNull)
  messages     SupportTicketMessage[]

  @@map("support_tickets")
}

model SupportTicketMessage {
  id        BigInt        @id @default(autoincrement())
  ticketId  BigInt        @map("ticket_id")
  senderId  BigInt?       @map("sender_id")
  message   String        @db.Text
  createdAt DateTime      @default(now()) @map("created_at")
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    User?         @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@map("support_ticket_messages")
}

model Notification {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt?  @map("user_id")
  cafeId    BigInt?  @map("cafe_id")
  title     String   @db.VarChar(255)
  message   String   @db.Text
  type      String   @db.VarChar(30)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  cafe      Cafe?    @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ActivityLog {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt?  @map("user_id")
  cafeId      BigInt?  @map("cafe_id")
  module      String   @db.VarChar(100)
  action      String   @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  cafe        Cafe?    @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}
