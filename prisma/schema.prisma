// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum UserStatus {
  active
  suspended
  pending
}

enum CafeStatus {
  active
  trial
  expired
  suspended
  pending
  archived
}

enum OrderStatus {
  pending
  confirmed
  preparing
  ready
  completed
  cancelled
}

enum OrderType {
  dine_in
  car
  pickup
}

enum PaymentStatus {
  paid
  unpaid
  pending
  overdue
  refunded
}

enum SubscriptionStatus {
  trial
  active
  expired
  cancelled
  suspended
}

// --- Auth & RBAC ---

model User {
  id              Int        @id @default(autoincrement())
  uuid            String     @unique @default(uuid()) @db.Uuid
  fullName        String     @map("full_name")
  email           String     @unique
  phone           String?
  passwordHash    String?    @map("password_hash")
  avatar          String?
  status          UserStatus @default(active)
  lastLoginAt     DateTime?  @map("last_login_at")
  emailVerifiedAt DateTime?  @map("email_verified_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")

  // Relations
  userRoles       UserRole[]
  ownedCafes      Cafe[]     @relation("CafeOwner")
  cafeUsers       CafeUser[]

  @@map("users")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  displayName String   @map("display_name")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  cafeUsers       CafeUser[]

  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  displayName String   @map("display_name")
  module      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId Int  @map("user_id")
  roleId Int  @map("role_id")
  user   User @relation(fields: [userId], references: [id])
  role   Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// --- Cafe Management ---

model Cafe {
  id               Int        @id @default(autoincrement())
  uuid             String     @unique @default(uuid()) @db.Uuid
  cafeCode         String     @unique @map("cafe_code")
  name             String
  slug             String     @unique
  logo             String?
  description      String?
  ownerUserId      Int?       @map("owner_user_id")
  phone            String?
  email            String?
  city             String
  status           CafeStatus @default(pending)
  currency         String     @default("USD")
  joinedAt         DateTime?  @map("joined_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  deletedAt        DateTime?  @map("deleted_at")

  // Relations
  owner         User?          @relation("CafeOwner", fields: [ownerUserId], references: [id])
  branches      CafeBranch[]
  cafeUsers     CafeUser[]
  subscriptions Subscription[]
  tables        CafeTable[]
  categories    MenuCategory[]
  orders        Order[]

  @@index([ownerUserId])
  @@index([status])
  @@map("cafes")
}

model CafeBranch {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique @default(uuid()) @db.Uuid
  cafeId       Int      @map("cafe_id")
  branchCode   String   @map("branch_code")
  name         String
  city         String?
  address      String?
  status       String   @default("active")
  isMainBranch Boolean  @default(false) @map("is_main_branch")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  cafe       Cafe           @relation(fields: [cafeId], references: [id])
  cafeUsers  CafeUser[]
  tables     CafeTable[]
  categories MenuCategory[]
  orders     Order[]

  @@map("cafe_branches")
}

model CafeUser {
  id       Int     @id @default(autoincrement())
  cafeId   Int     @map("cafe_id")
  userId   Int     @map("user_id")
  branchId Int?    @map("branch_id")
  roleId   Int     @map("role_id")
  status   String  @default("active")

  // Relations
  cafe   Cafe        @relation(fields: [cafeId], references: [id])
  user   User        @relation(fields: [userId], references: [id])
  branch CafeBranch? @relation(fields: [branchId], references: [id])
  role   Role        @relation(fields: [roleId], references: [id])

  @@map("cafe_users")
}

// --- Subscriptions ---

model Plan {
  id               Int      @id @default(autoincrement())
  uuid             String   @unique @default(uuid()) @db.Uuid
  name             String
  slug             String   @unique
  description      String?
  monthlyPrice     Decimal  @map("monthly_price") @db.Decimal(10, 3)
  yearlyPrice      Decimal  @map("yearly_price") @db.Decimal(10, 3)
  currency         String   @default("USD")
  maxBranches      Int      @default(1) @map("max_branches")
  maxTables        Int      @default(10) @map("max_tables")
  maxProducts      Int      @default(50) @map("max_products")
  maxStaffUsers    Int      @default(3) @map("max_staff_users")
  trialDays        Int      @default(14) @map("trial_days")
  isPopular        Boolean  @default(false) @map("is_popular")
  status           String   @default("active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id               Int                @id @default(autoincrement())
  uuid             String             @unique @default(uuid()) @db.Uuid
  cafeId           Int                @map("cafe_id")
  planId           Int                @map("plan_id")
  subscriptionType String             @map("subscription_type")
  startDate        DateTime           @map("start_date")
  endDate          DateTime           @map("end_date")
  amount           Decimal            @db.Decimal(10, 3)
  totalAmount      Decimal            @map("total_amount") @db.Decimal(10, 3)
  currency         String             @default("USD")
  status           SubscriptionStatus @default(active)
  paymentStatus    PaymentStatus      @default(pending) @map("payment_status")
  autoRenew        Boolean            @default(true) @map("auto_renew")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  // Relations
  cafe Cafe @relation(fields: [cafeId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

// --- Menu & Catalog ---

model MenuCategory {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid()) @db.Uuid
  cafeId      Int      @map("cafe_id")
  branchId    Int?     @map("branch_id")
  name        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  cafe      Cafe        @relation(fields: [cafeId], references: [id])
  branch    CafeBranch? @relation(fields: [branchId], references: [id])
  menuItems MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id              Int      @id @default(autoincrement())
  uuid            String   @unique @default(uuid()) @db.Uuid
  cafeId          Int      @map("cafe_id")
  categoryId      Int      @map("category_id")
  name            String
  description     String?
  image           String?
  price           Decimal  @db.Decimal(10, 3)
  preparationTime Int?     @map("preparation_time")
  isAvailable     Boolean  @default(true) @map("is_available")
  status          String   @default("active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  category   MenuCategory @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@map("menu_items")
}

// --- Floor & Tables ---

model CafeTable {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid()) @db.Uuid
  cafeId      Int      @map("cafe_id")
  branchId    Int      @map("branch_id")
  tableNumber String   @map("table_number")
  seatsCount  Int      @default(2) @map("seats_count")
  status      String   @default("available")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  cafe   Cafe       @relation(fields: [cafeId], references: [id])
  branch CafeBranch @relation(fields: [branchId], references: [id])
  orders Order[]

  @@map("cafe_tables")
}

// --- Orders ---

model Order {
  id            Int         @id @default(autoincrement())
  uuid          String      @unique @default(uuid()) @db.Uuid
  cafeId        Int         @map("cafe_id")
  branchId      Int         @map("branch_id")
  tableId       Int?        @map("table_id")
  orderNumber   String      @unique @map("order_number")
  orderType     OrderType   @default(dine_in) @map("order_type")
  subtotal      Decimal     @db.Decimal(10, 3)
  totalAmount   Decimal     @map("total_amount") @db.Decimal(10, 3)
  status        OrderStatus @default(pending)
  paymentStatus String      @default("unpaid") @map("payment_status")
  placedAt      DateTime    @default(now()) @map("placed_at")
  completedAt   DateTime?   @map("completed_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  // Relations
  cafe       Cafe        @relation(fields: [cafeId], references: [id])
  branch     CafeBranch  @relation(fields: [branchId], references: [id])
  table      CafeTable?  @relation(fields: [tableId], references: [id])
  orderItems OrderItem[]

  @@map("orders")
}

model OrderItem {
  id         Int     @id @default(autoincrement())
  orderId    Int     @map("order_id")
  menuItemId Int     @map("menu_item_id")
  itemName   String  @map("item_name")
  unitPrice  Decimal @map("unit_price") @db.Decimal(10, 3)
  quantity   Int
  totalPrice Decimal @map("total_price") @db.Decimal(10, 3)

  // Relations
  order    Order    @relation(fields: [orderId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}
